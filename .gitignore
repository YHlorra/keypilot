# Rust / Cargo
/src-tauri/target/
**/*.rs.bk
Cargo.lock.bak

# Tauri
/src-tauri/gen/

# Node / pnpm
/node_modules/                       # worktree-root junction (Windows: webui/node_modules)
/webui/node_modules/
/webui/dist/
/webui/.vite/
/webui/*.local

# Playwright transient artifacts (baselines live under tests/__screenshots__/)
/webui/test-results/
/webui/playwright-report/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Env
.env
.env.local
.env.*.local

# 临时
/tmp/
*.tmp
*.bak

# Deepwork progress
.slim/deepwork/

# Reference repos cloned for local code-reading (not part of our code)
docs/references/

# Agent session state (omc / nezha / etc.)
.omc/
.nezha/

# Tauri / Vite transient logs (not the *.log glob — these have no extension)
.tauri.err
.vite.err

# TRAE IDE specs workspace — committed on `docs` branch only, ignored everywhere else
.trae/

# Root-only debug output from ad-hoc cargo/tsc invocations (transient)
*.txt

# Icon generation scratch (final icons live under src-tauri/icons/)
src-tauri/icons/_candidates/
